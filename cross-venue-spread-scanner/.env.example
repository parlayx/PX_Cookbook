# REST key (markets, search, match), used by both scan and live.
PARX_API_KEY=parx_your_api_key_here
PARX_API_URL=https://api.parlayx.com

# Stream key (parx_stream_...), used by `npm run live` only.
PARX_STREAM_KEY=parx_stream_your_stream_key_here
PARX_STREAM_URL=wss://wss.parlayx.com/v1/orderbook
